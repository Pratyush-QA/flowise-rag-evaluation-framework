# ============================================================
# Flowise RAG Evaluation Framework - Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to GitHub

OPENAI_API_KEY=your_openai_api_key_here
RAGAS_APP_TOKEN=your_ragas_app_token_here

# Flowise Configuration
FLOWISE_API_URL=http://localhost:3000
FLOWISE_CHATFLOW_ID=your_chatflow_id_here

# Optional: Only required if Flowise API Auth is enabled
FLOWISE_API_KEY=your_flowise_api_key_if_auth_enabled
